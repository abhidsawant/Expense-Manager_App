{
  "expo": {
    "name": "ExpenseFlow",
    "slug": "expense_manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0014"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.expenseflow.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access for receipts.",
        "NSPhotoLibraryUsageDescription": "We need photo access for receipts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.expenseflow.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0014"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-image-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0D0014",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "df8281f9-6597-4402-ad15-2fc8aac26c1a"
      }
    }
  }
}
